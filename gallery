<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Gallery – Scottish Norwegian Society</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #ffffff; }

        header { background: #00264d; color: white; text-align: center; padding-bottom: 10px; }
        header img { width: 100%; height: 150px; object-fit: cover; display: block; }

        nav { background: #ba0c2f; padding: 10px 0; border-bottom: 4px solid #00264d; }
        nav ul { list-style: none; margin: 0; padding: 0; text-align: center; }
        nav li { display: inline-block; margin: 0 12px; }
        nav a { color: white; text-decoration: none; font-weight: bold; font-size: 16px; }
        nav a:hover { text-decoration: underline; }

        main { max-width: 900px; margin: auto; padding: 30px; background: #ffffff; }
        h2 { color: #00264d; }

        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }

        .gallery img {
            width: 100%;
            border: 3px solid #00264d;
        }

        footer { text-align: center; padding: 20px; background: #00264d; color: white;
                 border-top: 4px solid #ba0c2f; margin-top: 40px; }

        /* Mobile improvements */
        @media (max-width: 600px) {
            header img { height: 120px; }
            nav ul { display: block; text-align: left; padding-left: 20px; }
            nav li { display: block; margin: 8px 0; }
            nav a { font-size: 18px; }
            main { padding: 20px; }
            h1 { font-size: 24px; }
            h2 { font-size: 20px; }
        }
    </style>
</head>

<body>

